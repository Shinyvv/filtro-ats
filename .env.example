DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ats_mvp"
SESSION_SECRET="change-this-secret"

# Proveedor de IA: "mock" (default, sin costo), "gemini" u "openrouter".
AI_PROVIDER="mock"

# Clave PRIVADA de Gemini (GCP). NUNCA usar NEXT_PUBLIC_ ni exponerla al frontend.
GEMINI_API_KEY=""

# Clave PRIVADA de OpenRouter. NUNCA usar NEXT_PUBLIC_ ni exponerla al frontend.
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free"

APP_URL="http://localhost:3000"
APP_NAME="Filtro ATS Demo"
